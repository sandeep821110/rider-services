# Required
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/order_services

# Redis (for OTP storage)
# If using local Redis: redis://localhost:6379
REDIS_URL=redis://default:pass@host:port

# RabbitMQ (for email queue - optional, falls back to direct email)
RABBITMQ_URL=amqp://localhost:5672

# Email (for direct OTP email fallback when RabbitMQ is down)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Rider service
RIDER_SERVICE_PORT=7011
JWT_ACCESS_SECRET=your-jwt-secret
JWT_RIDER_EXPIRY=7d
